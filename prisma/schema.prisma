// Schema Prisma — Escola Flávio Milhomem
// Camada 3 (Backend e CRM) do Guia de Desenvolvimento Web.
// Adapter Neon serverless habilitado em src/lib/prisma.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// IDENTIDADE E ACESSO
// ============================================================

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String?        // null = só magic link
  role          UserRole       @default(ALUNO)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relações
  orders            Order[]
  subscriptions     Subscription[]
  comments          Comment[]
  utmEvents         UTMEvent[]
  posts             BlogPost[]
  lessonProgress    UserLessonProgress[]
  certificates      Certificate[]

  @@index([email])
}

enum UserRole {
  ALUNO
  ADMIN
}

// ============================================================
// CATÁLOGO E COMPRA
// ============================================================

model Product {
  id            String               @id @default(cuid())
  slug          String               @unique
  name          String
  shortTitle    String?              // título curto (área do aluno)
  tagline       String?
  catalogLabel  String?              // rótulo de catálogo ("Curso gravado · …")
  description   String               @db.Text
  type          ProductType
  priceCents    Int
  coverImage    String?              // capa (card do aluno, listagens)
  bannerImage   String?              // banner (hero / vitrine do curso)
  coverGradient Json?                // gradiente do hero/card: { from, via?, to, angle? }
  publishStatus ProductPublishStatus @default(DRAFT)
  publishedAt   DateTime?
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  orders        Order[]
  subscriptions Subscription[]
  modules       Module[]
  lessons       Lesson[]
  certificates  Certificate[]

  @@index([slug])
  @@index([publishStatus])
}

enum ProductPublishStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum ProductType {
  COHORT          // Edição Lançamento (cohort de 12 semanas)
  TRIPWIRE        // Masterclass / análise pontual
  COMUNIDADE      // Assinatura mensal
  EBOOK           // Eduzz legado
}

model Order {
  id              String        @id @default(cuid())
  userId          String
  productId       String
  status          OrderStatus
  amountCents     Int
  paymentMethod   PaymentMethod
  pagarmeChargeId String?       @unique
  pagarmeOrderId  String?       @unique
  /// QR code, URL do boleto etc. — retorno da API Pagar.me (MVP checkout).
  paymentPayload  Json?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  refundRequests RefundRequest[]

  @@index([userId])
  @@index([status])
}

/// Solicitação de reembolso do aluno (livro-guia 4.7): aluno solicita pela
/// área logada, admin aprova (executa estorno Pagar.me) ou rejeita.
/// Regra "1 pedido aberto por Order" (REQUESTED/APPROVED) é garantida em
/// código (Prisma não suporta unique condicional) — ver src/lib/refunds.
model RefundRequest {
  id              String       @id @default(cuid())
  orderId         String
  userId          String
  status          RefundStatus @default(REQUESTED)
  /// Motivo informado pelo aluno.
  reason          String?      @db.Text
  /// Valor elegível calculado (centavos) — o que será/foi estornado.
  amountCents     Int?
  decidedByUserId String?
  decidedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
}

/// Idempotência de webhooks Pagar.me (eventId = payload.id).
model PagarmeWebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  AUTHORIZED
  PAID
  REFUSED
  REFUNDED
  CHARGEDBACK
}

enum PaymentMethod {
  CARD
  PIX
  BOLETO
  /// Concessão manual (turma fundadora / cortesia) — sem Pagar.me.
  MANUAL
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  productId          String
  status             SubscriptionStatus
  pagarmeSubId       String?            @unique
  startedAt          DateTime           @default(now())
  canceledAt         DateTime?
  nextBillingAt      DateTime?

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

// ============================================================
// PLATAFORMA DE CURSO
// ============================================================

model Module {
  id        String   @id @default(cuid())
  productId String
  slug      String
  title     String
  subtitle  String?
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([productId, slug])
  @@index([productId, position])
}

model Lesson {
  id           String    @id @default(cuid())
  productId    String
  moduleId     String?
  slug         String
  title        String
  description  String?   @db.Text
  summary      String?   @db.Text // resumo exibido na aba "Sobre" da aula
  keyPoints    Json?              // string[] — pontos-chave da aula
  materials    Json?              // { title, pages, sizeKb }[] — materiais de apoio
  coverImage   String?   // thumbnail da aula no painel do aluno
  videoId      String?   // Cloudflare Stream UID
  videoSrc     String?   // caminho do mp4 (manifest) — fallback ao videoId/Stream
  posterImage  String?   // poster do player
  slidesUrl    String?   // caminho dos slides (pptx/pdf)
  position     Int
  durationSec  Int?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  product   Product              @relation(fields: [productId], references: [id])
  module    Module?              @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  comments  Comment[]
  progress  UserLessonProgress[]

  @@unique([productId, slug])
  @@index([productId, position])
  @@index([moduleId, position])
}

model UserLessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  watchedSec  Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Comment {
  id               String           @id @default(cuid())
  userId           String
  lessonId         String
  parentId         String?
  content          String           @db.Text
  moderationStatus ModerationStatus @default(APPROVED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  lesson   Lesson    @relation(fields: [lessonId], references: [id])
  parent   Comment?  @relation("CommentTree", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentTree")

  @@index([lessonId])
  @@index([userId])
}

enum ModerationStatus {
  APPROVED
  PENDING
  REJECTED
}

// ============================================================
// MARKETING (CRM CODADO)
// ============================================================

model LeadMagnet {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  fileUrl     String?
  description String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  leads Lead[]
}

model Lead {
  id            String      @id @default(cuid())
  email         String
  name          String?
  source        String?     // ex: "newsletter", "calculadora", "isca-stj"
  leadMagnetId  String?
  optInAt       DateTime?
  doubleOptInAt DateTime?
  /// LGPD — descadastro. Setado bloqueia qualquer envio (sequência ou campanha).
  unsubscribedAt DateTime?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  createdAt     DateTime    @default(now())

  leadMagnet LeadMagnet? @relation(fields: [leadMagnetId], references: [id])

  @@unique([email, leadMagnetId])
  @@index([email])
}

model EmailCampaign {
  id           String           @id @default(cuid())
  slug         String           @unique
  name         String
  subject      String
  bodyMarkdown String           @db.Text
  status       CampaignStatus   @default(DRAFT)
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELED
}

/// Inscrição de um lead numa sequência automática de e-mail (guia 6.13).
/// Motor drenado de hora em hora pelo cron /api/cron/email-sequences.
model EmailSequenceEnrollment {
  id          String              @id @default(cuid())
  leadEmail   String
  sequence    EmailSequence
  currentStep Int                 @default(0)
  status      EmailSequenceStatus @default(ACTIVE)
  nextSendAt  DateTime?
  /// Pós-compra / carrinho abandonado — referência ao pedido de origem.
  orderId     String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([leadEmail, sequence])
  @@index([status, nextSendAt])
}

enum EmailSequence {
  WELCOME
  LAUNCH
  ABANDONED_CART
  POST_PURCHASE
}

enum EmailSequenceStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

model UTMEvent {
  id          String   @id @default(cuid())
  userId      String?
  shortCode   String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  destination String
  ipHash      String?
  userAgent   String?  @db.Text
  geo         String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([shortCode])
  @@index([utmCampaign])
}

// ============================================================
// CONTEÚDO (BLOG)
// ============================================================

model BlogPost {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  excerpt     String?      @db.Text
  body        String       @db.Text
  coverImage  String?      // URL da imagem de destaque do WordPress
  status      BlogStatus   @default(DRAFT)
  category    BlogCategory @default(GERAL)
  publishedAt DateTime?
  authorId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([authorId])
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum BlogCategory {
  ANALISE_DECISAO
  DOGMATICA
  COMENTARIO
  GERAL
}

// ============================================================
// CERTIFICADOS
// ============================================================

model Certificate {
  id        String   @id @default(cuid())
  hash      String   @unique // código público de validação (/certificado/[hash])
  userId    String
  productId String
  issuedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([hash])
}
