# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local
.env.production
# .env.example DEVE ser commitado

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/prisma/dev.db
/prisma/migrations/dev/

# IDE
.idea
*.swp
.cursor/

# Mídia de curso (local / CDN — não versionar no Git)
/public/curso/**/*.mp4
/public/curso/**/*.zip
/public/curso/milhomem/
/public/JPEG.zip
/public/PNG.zip
.env*.local
.pydeps/
.tmp_*.png

# Material estratégico interno — não subir (repo público)
calendario-editorial-*.html
docs/

# Gerador legado do checklist (101 nós) — NÃO é o mestre de 308
.organograma-autogen.html

