# =============================================================
# Escola Flávio Milhomem — variáveis de ambiente
# =============================================================
# Copie para .env.local (dev) ou configure em Vercel (prod).
# NUNCA commite .env, .env.local, .env.production.

# === App ===
NEXT_PUBLIC_SITE_URL="https://escolaflaviomilhomem.com.br"

# === Banco de dados (Neon serverless) ===
# Connection pooler URL — formato: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=""

# === Autenticação (jose JWT) ===
# Mínimo 32 chars. Gerar com: openssl rand -base64 48
AUTH_SECRET=""

# === Pagar.me (Stone) ===
# Pegar em https://dashboard.pagar.me/ após KYC
PAGARME_PUBLIC_KEY=""
PAGARME_SECRET_KEY=""
PAGARME_WEBHOOK_SECRET=""

# === E-mail transacional (Resend) ===
RESEND_API_KEY=""
RESEND_FROM_EMAIL="contato@escolaflaviomilhomem.com.br"

# === Cloudflare Stream (vídeo) ===
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_TOKEN=""

# === Cloudflare R2 (armazenamento frio) ===
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT=""

# === Tracking ===
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=""
META_CAPI_ACCESS_TOKEN=""
META_CAPI_PIXEL_ID=""

# === PostHog (product analytics auto-hospedado) ===
# Quando vazio, posthog-js não é inicializado.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# === Sentry ===
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# === Upstash Redis (rate limiting) ===
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# === Eduzz (transitório, leitura de venda antiga) ===
EDUZZ_API_KEY=""

# === Dev only — bypass de auth para navegar /aluno/* e /professor/* sem DB ===
# Valores aceitos (case-sensitive):
#   "1" ou "aluno"        → injeta sessão mock como Rafael Andrade (role: aluno)
#   "professor" ou "admin" → injeta sessão mock como Flávio Milhomem (role: admin)
#   vazio ou outro valor   → desabilitado, fluxo de auth real
# Em produção, o helper `getDevFakeSession()` retorna null mesmo com a
# flag setada (guard duplo via NODE_ENV).
NEXT_PUBLIC_DEV_FAKE_SESSION=""
